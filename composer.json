{
    "name": "laravel/laravel",
    "type": "project",
    "description": "Laravel 11 upgraded project.",
    "keywords": [
        "laravel",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "ext-curl": "*",
        "ext-intl": "*",
        "ext-json": "*",
        "ext-pdo": "*",
        "guzzlehttp/guzzle": "^7.8",
        "inertiajs/inertia-laravel": "^2.0",
        "kris/laravel-form-builder": "^1.53",
        "kriswallsmith/buzz": "^1.2",
        "laravel/cashier": "^16.1",
        "laravel/framework": "^12.0",
        "laravel/sanctum": "^4.0",
        "laravel/tinker": "^2.8",
        "laravel/ui": "^4.5",
        "livewire/livewire": "^3.10@dev",
        "maatwebsite/excel": "^3.1",
        "nyholm/psr7": "^1.8",
        "simplesoftwareio/simple-qrcode": "^4.2",
        "spatie/enum": "*",
        "spatie/laravel-comments": "*",
        "spatie/laravel-data": "^4.19",
        "spatie/laravel-medialibrary": "^11.0.0",
        "spatie/laravel-medialibrary-pro": "*@dev",
        "spatie/laravel-permission": "^6.23",
        "spatie/laravel-query-builder": "^6.4",
        "spatie/laravel-view-models": "^1.6",
        "staudenmeir/belongs-to-through": "^2.14",
        "stechstudio/backoff": "^1.2",
        "tightenco/ziggy": "^2.6",
        "yajra/laravel-datatables": "^12.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.21",
        "laravel/boost": "^2.2",
        "laravel/breeze": "^2.3",
        "laravel/pint": "^1.10",
        "laravel/sail": "^1.29",
        "mockery/mockery": "^1.6",
        "phpunit/phpunit": "^11.0"
    },
    "repositories": [
        {
            "type": "path",
            "url": "packages/spatie-laravel-comments",
            "options": {
                "symlink": false
            }
        },
        {
            "type": "path",
            "url": "packages/laravel-medialibrary-pro",
            "options": {
                "symlink": false
            }
        }
    ],
    "autoload": {
        "files": [
            "app/Helpers/shared.php",
            "app/Helpers/formatter.php"
        ],
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/",
            "Domain\\": "src/Domain",
            "Support\\" : "src/Support/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
